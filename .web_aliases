# Source this file from your shell configuration to enable custom
# commands that open specific websites.
# These commands are hidden by default because the file name begins with a dot.

# Quick website openers
comtech() {
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "http://ksk432.com/ComTech.github.io/" >/dev/null 2>&1 &
  else
    open "http://ksk432.com/ComTech.github.io/"
  fi
}

mkomg() {
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "https://mkomg.lol" >/dev/null 2>&1 &
  else
    open "https://mkomg.lol"
  fi
}

shinitai() {
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "https://shinitai.shop" >/dev/null 2>&1 &
  else
    open "https://shinitai.shop"
  fi
}
